# CollabMind AI Backend Environment Variables
# Copy this to .env and fill in your values

# App
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (SQLite by default - no setup needed)
DATABASE_URL=sqlite:///./collabmind.db

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# AI (mock by default - add real key for production)
OPENAI_API_KEY=mock
AI_MODE=mock

# OAuth (optional - email/password works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:8000
